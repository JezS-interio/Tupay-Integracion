# Firebase Configuration
# Get these from Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Cloudflare R2 Configuration (Server-side only — never expose these publicly)
# Get these from Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Cloudflare R2 Public URL (Client-side accessible)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# MobileAPI.dev Configuration
# Get your API key from: https://mobileapi.dev
MOBILEAPI_KEY=

# Resend Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=

# TuPay Configuration
# Credentials from: https://merchants-stg.tupaypagos.com → Deposit Credentials
TUPAY_API_KEY=
TUPAY_API_PASSPHRASE=
TUPAY_API_SIGNATURE=
TUPAY_BASE_URL=https://api-stg.tupayonline.com
# Set to "production" when going live, use "staging" for testing
TUPAY_ENVIRONMENT=staging

# Izipay Configuration
# Credentials from: https://www.izipay.pe/ (o tu panel de Izipay)
IZIPAY_API_KEY=
IZIPAY_API_SECRET=
IZIPAY_BASE_URL=https://api.micuentaweb.pe

# App public URL (used for TuPay callback/redirect URLs)
# Dev: http://localhost:3000 | Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=
